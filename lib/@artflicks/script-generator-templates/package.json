{
  "name": "@artflicks/script-generator-templates",
  "version": "1.0.0",
  "description": "Script generator templates with system prompts for AI video/image generation",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "pack": "npm run build && npm pack"
  },
  "keywords": [
    "script",
    "templates",
    "ai",
    "video-generation"
  ],
  "author": "ArtFlicks",
  "license": "MIT",
  "dependencies": {
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.3",
    "esbuild": "^0.24.0"
  }
}