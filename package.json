{
  "name": "cloudflare-workers-create-story",
  "version": "1.0.0",
  "type": "module",
  "description": "Cloudflare Workers service for creating short stories with AI-generated images and audio",
  "main": "src/index.ts",
  "workspaces": [
    "lib/@artflicks/*"
  ],
  "scripts": {
    "dev": "wrangler dev",
    "dev:staging": "wrangler dev --env staging",
    "dev:remote": "wrangler dev --remote",
    "deploy": "wrangler deploy --env=\"\"",
    "log": "wrangler tail --format pretty",
    "log:capture": "mkdir -p logs && wrangler tail --format json 2>&1 | tee logs/worker.log",
    "log:capture:stg": "mkdir -p logs && wrangler tail --env staging --format json 2>&1 | tee logs/staging.log",
    "log:capture:prod": "mkdir -p logs && wrangler tail --env production --format json 2>&1 | tee logs/production.log",
    "deploy:stg": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
    "monitor:stg": "npx wrangler tail --env staging --format pretty",
    "monitor:prod": "npx wrangler tail --env production --format pretty",
    "type-check": "npx tsc --noEmit",
    "unused": "npx knip --fix --fix-type exports",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:templates": "vitest run src/generation-engine/__tests__/templates/",
    "test:services": "vitest run src/generation-engine/__tests__/services/",
    "test:providers": "vitest run src/generation-engine/__tests__/providers/",
    "test:coverage": "vitest run --config vitest.coverage.config.ts --coverage --coverage.reporter=text --coverage.reporter=html --coverage.reportsDirectory=coverage",
    "test:coverage:open": "vitest run --config vitest.coverage.config.ts --coverage --coverage.reporter=text --coverage.reporter=html --coverage.reportsDirectory=coverage && open coverage/index.html",
    "test:blocks": "vitest run src/generation-engine/__tests__/blocks/",
    "test:workflow": "vitest run src/generation-engine/__tests__/workflow/",
    "test:e2e": "vitest run src/generation-engine/__tests__/e2e/",
    "test:integration": "vitest run src/generation-engine/__tests__/integration.spec.ts",
    "formatte": "npm run unused && npm run type-check"
  },
  "keywords": [
    "cloudflare-workers",
    "ai",
    "story-generation"
  ],
  "author": "Rakshith Raj S",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.0",
    "@cloudflare/workers-types": "^4.20241106.0",
    "@vitest/coverage-v8": "^4.1.0",
    "knip": "^5.78.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.51.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.1",
    "@artflicks/video-compiler": "1.0.0",
    "@supabase/supabase-js": "^2.39.3",
    "ai": "^6.0.3",
    "replicate": "^1.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.2.1"
  }
}
